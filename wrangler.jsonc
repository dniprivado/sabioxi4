{
  "name": "sabioxi3",
  "main": ".open-next/worker.js",
  "compatibility_date": "2024-04-03",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "build": {
    "command": "npm run build"
  },
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "sabioxi_db",
      "database_id": "your-database-id-here"
    }
  ],
  "observability": {
    "enabled": true
  }
}
